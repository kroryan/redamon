# =============================================================================
# Knowledge Base Embedding Configuration
# =============================================================================
# Controls how the KB generates vector embeddings for ingestion and query.
# When KB_EMBEDDING_USE_API is false (default), the local sentence-transformers
# model runs on CPU/GPU inside the agent container.
#
# IMPORTANT: Ingestion and query MUST use the same embedding model.
# Switching models requires a full KB rebuild:
#   make -C knowledge_base kb-rebuild-lite MODE=docker

# Use an external API for KB embedding (ingestion + query)
KB_EMBEDDING_USE_API=false

# API base URL (only used when KB_EMBEDDING_USE_API=true)
# Uses the OpenAI SDK, which works with any OpenAI-compatible API.
# Examples:
#   OpenAI:      https://api.openai.com/v1  (default if left empty)
#   Ollama:      http://host.docker.internal:11434/v1
#   LiteLLM:     http://host.docker.internal:4000/v1
#   Together AI: https://api.together.xyz/v1
#   Azure:       https://<resource>.openai.azure.com/openai/deployments/<deployment>
#   vLLM:        http://host.docker.internal:8000/v1
#   Fireworks:   https://api.fireworks.ai/inference/v1
KB_EMBEDDING_API_BASE_URL=

# API key (only used when KB_EMBEDDING_USE_API=true)
KB_EMBEDDING_API_KEY=

# API model name (only used when KB_EMBEDDING_USE_API=true)
# OpenAI:      text-embedding-3-small (1536 dim), text-embedding-3-large (3072 dim)
# Ollama:      nomic-embed-text, mxbai-embed-large, all-minilm
# Together AI: togethercomputer/m2-bert-80M-8k-retrieval
KB_EMBEDDING_API_MODEL=text-embedding-3-small

# =============================================================================
# NVD API Key (optional, speeds up NVD ingestion 10x)
# Get a free key: https://nvd.nist.gov/developers/request-an-api-key
# =============================================================================
NVD_API_KEY=

# =============================================================================
# Memory Governor (RAM-aware dual-cap) — ALL OPTIONAL
# =============================================================================
# RedAmon caps every RAM-heavy operation with two limits at once: the value you
# configure (the HARD CEILING) and a DYNAMIC cap derived from the RAM actually
# available at runtime. The effective value is always the smaller of the two, so
# it only ever throttles DOWN under memory pressure, never above your ceiling.
#
# Leave every variable below EMPTY to use the built-in default (shown in
# parentheses). Set a value only to override. Memory sizes accept Docker-style
# suffixes: 512m, 2g, etc. Byte figures for on-demand units are normally MEASURED
# by the calibration step (resource_profile.json), not hand-set.

# --- Master switch ---------------------------------------------------------
# Turn the whole memory governor on/off (default: on). When off, behavior is the
# legacy static-limits-only mode.
REDAMON_MEM_GOVERNOR=

# --- Ratio model (for in-process concurrency: threads, -c/-t, pool widths) --
# Available-RAM ratio (available/total) at/above which parallelism runs at the
# full configured ceiling (default: 0.50).
MEM_SCALE_HIGH=
# Available-RAM ratio at/below which parallelism is throttled to the floor
# (default: 0.15).
MEM_SCALE_LOW=
# Floor scale factor: parallelism never drops below this fraction of the ceiling
# (default: 0.15).
MEM_SCALE_FLOOR=
# Seconds to cache the /proc/meminfo read so a wide fan-out doesn't hammer it
# (default: 2).
MEM_READ_TTL_S=

# --- Byte-budget model (for anything that costs real megabytes) ------------
# Safety margin added on top of EVERY measured memory figure before it is used
# (default: 0.25, i.e. +25% over the measured peak).
MEM_SAFETY_TOLERANCE=
# Share of currently-available RAM a single memory-sink list or a single
# on-demand unit may claim (default: 0.10 = 10%).
MEM_BUDGET_FRACTION=
# Path to the calibration output holding measured bytes-per-unit and per-process
# envelope figures (default: resource_profile.json). Regenerate when tool
# versions change materially.
RESOURCE_PROFILE_PATH=

# --- Simultaneous recon scans (admission reservation ledger) ---------------
# RAM reserved for the OS/kernel, never handed to work (default: 2g).
OS_HEADROOM_MEM=
# Total RAM the always-on core services are expected to use; subtracted from the
# scan pool (default: measured, from resource_profile.json).
SERVICE_BASELINE_MEM=
# Expected peak RAM of one recon job (container + its sibling tools) — the unit
# the scan pool is divided into (default: measured, from resource_profile.json).
RECON_JOB_ENVELOPE_MEM=
# Hard ceiling on globally-concurrent recon scans across ALL projects
# (default: computed = scan_pool / RECON_JOB_ENVELOPE_MEM).
RECON_MAX_CONCURRENT_GLOBAL=

# --- Agent sessions / jobs -------------------------------------------------
# Max concurrent agent chat / WebSocket sessions
# (default: computed = available RAM x MEM_BUDGET_FRACTION / session envelope).
MAX_AGENT_SESSIONS=
# Max concurrent background agent jobs
# (default: computed from available RAM / background-job envelope).
MAX_BACKGROUND_JOBS=

# --- Per-container hard caps: on-demand scan containers ---------------------
# These are computed at SPAWN from the (RAM-scaled) parameters the container
# will run with, then clamped to PER_CONTAINER_MAX. Set one to force a fixed
# ceiling for that scan type instead (default: spawn-time envelope x headroom).
RECON_CONTAINER_MEM=
AI_ATTACK_MEM=
GVM_SCAN_MEM=
GITHUB_HUNT_MEM=
TRUFFLEHOG_MEM=

# --- Per-service hard caps: always-on services (static, steady-state) ------
# neo4j JVM max heap. MUST accompany the neo4j mem_limit or the JVM gets
# OOM-killed (default: sized from host RAM).
NEO4J_HEAP=
# neo4j page cache size (default: sized from host RAM).
NEO4J_PAGECACHE=
# Memory ceiling for the gvmd container (default: measured baseline share).
GVMD_MEM=
# Memory ceiling for the agent container (default: measured baseline share).
AGENT_MEM=
# Memory ceiling for the recon-orchestrator container.
RECON_ORCHESTRATOR_MEM=
# Memory ceiling for the webapp container.
WEBAPP_MEM=
# Memory ceiling for the postgres container.
POSTGRES_MEM=
# Memory ceiling for the kali-sandbox container.
KALI_MEM=

# --- Container cap ceiling & headroom --------------------------------------
# Absolute max any SINGLE container may use, so one container can never take the
# whole host and starve the database (default: ~55% of host RAM).
PER_CONTAINER_MAX=
# Multiplier that sets each container's hard cap ABOVE its admission envelope, so
# a normal peak is never killed and only true runaways are (default: 1.5).
CONTAINER_CAP_HEADROOM=

# --- Sibling tool containers (katana/nuclei/httpx/... via the broker) -------
# Hard memory ceiling injected into each sibling tool container by the docker
# broker (default: spawn-time per-tool envelope passed through by recon).
BROKER_TOOL_MEM_BYTES=

# --- MCP terminal sessions -------------------------------------------------
# Max concurrent kali-sandbox PTY terminal sessions (default: 5; further limited
# dynamically by available RAM).
TERMINAL_MAX_SESSIONS=

# --- Startup gate & swap cushion -------------------------------------------
# Set to 1 to SKIP the startup RAM-sufficiency check that refuses to boot when
# the host can't hold the core services (default: gate enabled).
REDAMON_SKIP_RAM_GATE=
# Set to 1 to set up a one-time compressed-RAM (zram) swap cushion on Linux, so
# brief overshoots degrade gracefully instead of OOM-killing (default: off).
REDAMON_ENABLE_ZRAM=

# ============================================================================
#  RedAmon single-host deploy config  --  cp .env.example .env  then edit
# ----------------------------------------------------------------------------
#  This is the deploy-TIME config for the operator's LOCAL machine. It is NOT the
#  application .env that redamon.sh generates on the server. Keep real .env* files
#  local and gitignored. A run is just:  ./deploy.sh init
#  CLI positionals override the connection fields:  ./deploy.sh init <IP> <AUTH> <USER>
# ============================================================================

# ============================================================================
#  CONNECTION -- how deploy.sh reaches the box (CLI positionals override these)
# ============================================================================
HOST_IP=                                   # public IP or DNS of the target server (required)
REMOTE_USER=ubuntu                          # ssh sudoer (ubuntu / admin / root-capable)
SSH_KEY_PATH=~/.ssh/redamon.pem             # key auth (recommended). LOCAL-only; never copied to host
SSH_PASSWORD=                               # password-auth fallback; needs local sshpass. Discouraged
SSH_PORT=22                                 # non-standard SSH port if the host moved it

# ============================================================================
#  REPO -- public, no auth token required
# ============================================================================
REPO_URL=https://github.com/samugit83/redamon.git
REPO_BRANCH=master                          # branch to deploy
APP_DIR=redamon                             # stable checkout dir -> stable COMPOSE_PROJECT_NAME (DB-volume detection)
REDAMON_VERSION=                            # optional image/version stamp; blank -> redamon.sh default

# ============================================================================
#  PUBLIC ACCESS MODE -- the top-level switch for how the UI is exposed
# ----------------------------------------------------------------------------
#   https-domain : TLS on a DNS name        (letsencrypt|provided)  <- recommended / default
#   https-ip     : TLS on a bare IP         (self-signed|provided)  -> browser cert warning
#   http-domain  : plain HTTP on a DNS name (no TLS)                 -> LAB/TEST ONLY, insecure
#   http-ip      : plain HTTP on a bare IP  (no TLS)                 -> LAB/TEST ONLY, most insecure
# ============================================================================
ACCESS_MODE=https-domain
DOMAIN=redamon.example.com                  # required for *-domain modes; ignored for *-ip modes
HTTP_PORT=80                                # nginx listen + ufw. Keep 80 for Let's Encrypt (http-01 uses 80)
HTTPS_PORT=443                              # nginx listen + ufw. Change only when fronted by an LB presenting 443

# --- TLS (consulted only for https-* modes) ---
TLS_MODE=letsencrypt                        # letsencrypt (domain only) | provided | self-signed (ip only)
LETSENCRYPT_EMAIL=ops@example.com           # certbot registration/expiry mail (required for letsencrypt)
LETSENCRYPT_STAGING=false                   # true = LE staging cert while testing (dodges the rate limit)
SSL_CERT_LOCAL=cert/fullchain.pem           # provided mode: local paths (relative to this dir), SCP'd to host
SSL_KEY_LOCAL=cert/privkey.pem
SSL_KEY_PASSWORD=                           # if the provided key is encrypted
HSTS_ENABLE=true                            # https-only; auto-absent for http-* modes

# ============================================================================
#  ACCESS CONTROL / HOST HARDENING (defense-in-depth)
# ============================================================================
OPERATOR_ALLOW_CIDRS=203.0.113.10/32        # comma list: nginx allow gate + ufw 443 source (strongly recommended)
SSH_ALLOW_CIDRS=                            # comma list for ufw :22; blank -> falls back to OPERATOR_ALLOW_CIDRS
GATE_MODE=ip_allowlist                       # ip_allowlist | basic_auth | none
BASIC_AUTH_USER=                            # basic_auth mode only
BASIC_AUTH_PASS=
WS_REQUIRE_SESSION=true                      # nginx auth_request: require a valid webapp session
                                            # before ANY /ws/* upgrade. Keep true - 3 of the 4 agent
                                            # WS paths are unauthenticated (incl. a root PTY).
CSP_ENFORCE=false                            # false = Content-Security-Policy-Report-Only (safe default);
                                            # true = enforced CSP (promote after verifying graph+terminal render)
ENABLE_UFW=true                             # host firewall
ENABLE_SSH_HARDENING=true                   # key-only + no-root (password login left alone if you used a password)
ENABLE_FAIL2BAN=true                        # sshd + nginx jails
ENABLE_UNATTENDED_UPGRADES=true             # auto security patches

# ============================================================================
#  FEATURE FLAGS (map to redamon.sh install flags)
# ============================================================================
ENABLE_GVM=false                            # --gvm   (heavy; 10-20min feed sync; rotates admin/admin)
ENABLE_KB=false                             # --kbase (bakes ML embedding models; +~4.4GB image) -- the REAL KB switch
ENABLE_KB_REFRESH=false                     # kb-refresh sidecar
ENABLE_ZRAM=true                            # REDAMON_ENABLE_ZRAM compressed-RAM cushion
# NOTE: SKIP_KB is NOT an input -- redamon.sh derives it from the .kbase-enabled flag. Use ENABLE_KB only.

# ============================================================================
#  RESOURCES / HOST TUNING
# ============================================================================
SWAP_SIZE_GB=8                              # swapfile created when host RAM < 16GB; 0 = skip
REDAMON_SKIP_RAM_GATE=false                 # true bypasses redamon.sh's 8GB floor on tiny boxes (risky)
REDAMON_BUILD_PARALLEL=                     # cap concurrent image builds; blank -> redamon.sh auto-size
DOCKER_DNS=                                 # e.g. 8.8.8.8,8.8.4.4 -> /etc/docker/daemon.json if container DNS breaks
DOCKER_BUILD_CACHE_MAX_GB=                  # cap BuildKit cache (GB) via daemon.json auto-GC; blank -> Docker default. update's cache grows unbounded otherwise

# ============================================================================
#  ENGAGEMENT / OFFENSIVE KNOBS
# ============================================================================
REVSHELL_TARGET_CIDRS=                      # RoE target scope for './deploy.sh revshell-open' (per-engagement
                                            # 4444 exposure via a host socat forwarder + ufw). Empty = 4444 closed
TUNNELS_ENABLED=false                       # keep off on an already-exposed host

# ============================================================================
#  FIRST ADMIN (required for init -- the first admin user is created automatically)
# ============================================================================
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=                             # strong; there is NO app-layer lockout (nginx limit_req is the only brake)

# ============================================================================
#  OPTIONAL APP CONFIG appended to the server .env (LLM keys are set in the UI, not here)
# ============================================================================
NVD_API_KEY=
KB_EMBEDDING_USE_API=
KB_EMBEDDING_API_BASE_URL=
KB_EMBEDDING_API_KEY=

# ============================================================================
#  DEPLOY BEHAVIOUR / SAFETY
# ============================================================================
INIT_FORCE=false                            # true skips the typed "INIT" wipe confirmation (CI only -- dangerous)
BACKUP_BEFORE_UPDATE=false                  # (reserved) pg_dump + neo4j snapshot before update
DRY_RUN=false                               # print the resolved plan without mutating the host
VERBOSE=false                               # stream full remote command output
ALLOW_INSECURE=0                            # must be 1 to permit http-* modes (they invert the security posture)
